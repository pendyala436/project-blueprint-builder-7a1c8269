<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash screen theme used during cold start before Chrome attaches -->
    <style name="Theme.LauncherActivity" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowSplashScreenBackground">@color/backgroundColor</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/navigationColor</item>
        <item name="android:windowBackground">@color/backgroundColor</item>
    </style>
</resources>
